{
	"showSystem": true,
	"sidebar": { "width": 35 },
	"icons": {
		"send": "󰒊",
		"attach": "",
		"ratchet": "󰒓",
		"keys": "󱕵"
	},
	"theme": {
		"_bg":               "screen background; null keeps the terminal default",
		"bg":                null,
		"_fg":               "default text; null keeps the terminal default",
		"fg":                null,

		"_inputBg":          "text input background",
		"inputBg":           { "type": "hex", "value": "#39274C" },
		"_inputFg":          "text input foreground",
		"inputFg":           { "type": "hex", "value": "#E6BB85" },

		"_btnBg":            "unfocused button background",
		"btnBg":             { "type": "hex", "value": "#483160" },
		"_btnFg":            "unfocused button foreground",
		"btnFg":             { "type": "hex", "value": "#E1D6F8" },
		"_btnFocusBg":       "focused button background",
		"btnFocusBg":        { "type": "hex", "value": "#67478A" },
		"_btnFocusFg":       "focused button foreground",
		"btnFocusFg":        { "type": "hex", "value": "#E1D6F8" },
		"_btnDisabledBg":    "disabled button background",
		"btnDisabledBg":     { "type": "hex", "value": "#A1A0AD" },
		"_btnDisabledFg":    "disabled button foreground (invisible label)",
		"btnDisabledFg":     { "type": "hex", "value": "#222222" },

		"_barBg":            "chat input bar and sidebar tab strip background",
		"barBg":             { "type": "hex", "value": "#483160" },
		"_barFg":            "chat input bar foreground",
		"barFg":             { "type": "ansi16", "n": 15 },
		"_barBtnBg":         "unfocused background of the bar action buttons (send / attach / ratchet / attach-mode cancel); defaults to btnBg",
		"barBtnBg":          { "type": "hex", "value": "#483160" },
		"_barBtnFg":         "unfocused foreground of the bar action buttons; defaults to btnFg",
		"barBtnFg":          { "type": "hex", "value": "#87FF5F" },
		"_barBtnFocusBg":    "focused background of the bar action buttons; defaults to btnFocusBg",
		"barBtnFocusBg":     { "type": "ansi16", "n": 4 },
		"_barBtnFocusFg":    "focused foreground of the bar action buttons; defaults to btnFocusFg",
		"barBtnFocusFg":     { "type": "ansi16", "n": 15 },

		"_peer0":            "YOUR OWN username prefix in the chat scroll. reserved for self; peers never use it, so no peer can wear your color",
		"peer0":             { "type": "hex", "value": "#87FF5F" },
		"_peer1":            "peer username color, slot 1. each peer gets one of peer1-7 by join order, wrapping after 7 (never peer0 or the system color)",
		"peer1":             { "type": "ansi16", "n": 10 },
		"_peer2":            "peer username color, slot 2",
		"peer2":             { "type": "ansi16", "n": 12 },
		"_peer3":            "peer username color, slot 3",
		"peer3":             { "type": "ansi16", "n": 13 },
		"_peer4":            "peer username color, slot 4",
		"peer4":             { "type": "ansi16", "n": 11 },
		"_peer5":            "peer username color, slot 5",
		"peer5":             { "type": "ansi16", "n": 9 },
		"_peer6":            "peer username color, slot 6",
		"peer6":             { "type": "ansi16", "n": 5 },
		"_peer7":            "peer username color, slot 7",
		"peer7":             { "type": "ansi16", "n": 2 },
		"_yourMsg":          "own message body",
		"yourMsg":           { "type": "hex", "value": "#D4D4D4" },
		"_peerMsg":          "peer message body",
		"peerMsg":           { "type": "hex", "value": "#E1D6F8" },

		"_codeFg":           "inline code and fenced-block foreground",
		"codeFg":            { "type": "ansi16", "n": 15 },
		"_codeBg":           "fenced-block background fill",
		"codeBg":            { "type": "ansi16", "n": 8 },

		"_attachBg":         "attachment chip background",
		"attachBg":          { "type": "hex", "value": "#67478A" },
		"_attachFg":         "attachment chip foreground",
		"attachFg":          { "type": "hex", "value": "#E1D6F8" },
		"_attachSelectedBg": "attachment chip background when keyboard-selected",
		"attachSelectedBg":  { "type": "ansi16", "n": 2 },
		"_attachSelectedFg": "attachment chip foreground when keyboard-selected",
		"attachSelectedFg":  { "type": "ansi16", "n": 0 },
		"_barAttach":        "attach-mode icon prefacing the input box (foreground on barBg); defaults to attachBg",
		"barAttach":         { "type": "ansi16", "n": 6 },

		"_calloutBg":        "callout strip background in WaitingView",
		"calloutBg":         { "type": "hex", "value": "#C586C0" },
		"_calloutFg":        "callout strip foreground",
		"calloutFg":         { "type": "hex", "value": "#000000" },

		"_modalBg":          "modal body background",
		"modalBg":           { "type": "ansi16", "n": 0 },
		"_modalFg":          "modal body foreground",
		"modalFg":           { "type": "ansi16", "n": 15 },
		"_modalBorder":      "modal border ring",
		"modalBorder":       { "type": "ansi16", "n": 6 },
		"_modalTitle":       "modal title row",
		"modalTitle":        { "type": "ansi16", "n": 14 },

		"_disabled":         "secondary or muted UI text (status lines, attachment size, fingerprint hex, scroll bar)",
		"disabled":          { "type": "hex", "value": "#ADA4A0" },
		"_system":           "in-chat system notices and /help output (the 'system:' prefix and body); distinct from disabled so it recolors on its own",
		"system":            { "type": "256", "n": 250 },
		"_error":            "error text (parse errors, server errors, etc.)",
		"error":             { "type": "hex", "value": "#DB6088" },

		"_evtTime":          "event-log timestamp column",
		"evtTime":           { "type": "ansi16", "n": 8 },
		"_evtArrow":         "event-log direction glyph (right / left / dot)",
		"evtArrow":          { "type": "ansi16", "n": 15 },
		"_evtMsg":           "event-log summary body text",
		"evtMsg":            { "type": "ansi16", "n": 15 },
		"_evtKey":           "event-log expanded-detail key label",
		"evtKey":            { "type": "ansi16", "n": 8 },
		"_evtVal":           "event-log expanded-detail value",
		"evtVal":            { "type": "ansi16", "n": 15 },
		"_evtSelf":          "event-log username prefix when the user is you",
		"evtSelf":           { "type": "ansi16", "n": 5 },
		"_evtPeer":          "event-log username prefix when the user is a peer",
		"evtPeer":           { "type": "ansi16", "n": 6 },
		"_evtKindDefault":   "event-log kind column for uncategorized kinds",
		"evtKindDefault":    { "type": "ansi16", "n": 4 },
		"_evtKindError":     "event-log kind column for error, fatal, message-fail, claim-reject, decrypt-fail, send-fail",
		"evtKindError":      { "type": "ansi16", "n": 1 },
		"_evtKindMember":    "event-log kind column for join, rejoin, part, peer_joined, peer_left",
		"evtKindMember":     { "type": "ansi16", "n": 2 },
		"_evtKindRatchet":   "event-log kind column for ratchet, ratchet-step, ratchet-step-fwd, ratchet_step, ratchet_step_fwd",
		"evtKindRatchet":    { "type": "hex", "value": "#D99145" },

		"_keyFg":            "icons.keys glyph in the in-chat 'keys rotated' ratchet notice (any user)",
		"keyFg":             { "type": "ansi16", "n": 3 },
		"_ratchetTxtFg":     "'keys rotated' label text in the in-chat ratchet notice (any user)",
		"ratchetTxtFg":      { "type": "ansi16", "n": 8 }
	}
}
