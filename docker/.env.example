# Copy to docker/.env and fill in. The container EXITS immediately without DOMAIN.
# Both `sh docker/run up` and `docker compose` read this file.

# Public hostname Caddy serves and provisions a TLS cert for (required).
# Use localhost / 127.0.0.1 (optionally with :port) for HTTP-only local testing.
DOMAIN=your.covcom.domain

# Internal Bun relay port Caddy reverse-proxies /ws to.
PORT=3000

# Optional admin bearer token for privileged relay endpoints (leave blank to disable).
ADMIN_TOKEN=

# Room time-to-live in hours.
ROOM_TTL=24

# Max participants per room.
MAX_ROOM_SIZE=20
