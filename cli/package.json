{
	"//": "Custom zero-dependency TUI, no native bindings required.",
	"name": "@covcom/cli",
	"private": true,
	"type": "module",
	"scripts": {
		"test": "bun build.ts && bun test",
		"typecheck": "bunx --no-install tsc --noEmit -p tsconfig.json",
		"bundle": "bun build.ts",
		"dev": "bun build.ts && bun run src/main.ts",
		"build": "bun build.ts --compile",
		"build:all": "bun build.ts --compile --targets all",
		"build:mac-arm": "bun build.ts --compile --targets darwin-arm64",
		"build:mac-x64": "bun build.ts --compile --targets darwin-x64",
		"build:linux": "bun build.ts --compile --targets linux-x64",
		"build:win": "bun build.ts --compile --targets win32-x64"
	},
	"dependencies": {
		"@covcom/lib": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^25.9.1",
		"bun-types": "^1.3.14"
	}
}
