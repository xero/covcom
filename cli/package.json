{
	"//": "Custom zero-dependency TUI, no native bindings required.",
	"name": "@covcom/cli",
	"private": true,
	"type": "module",
	"scripts": {
		"test": "bun test",
		"bundle": "bun build.ts",
		"dev": "bun build.ts && bun run src/main.ts",
		"build": "bun build.ts --compile",
		"build:all": "bun run build:mac-arm && bun run build:mac-x64 && bun run build:linux && bun run build:win",
		"build:mac-arm": "bun build src/main.ts --compile --target bun-darwin-arm64  --outfile dist/covcom-macos-arm64",
		"build:mac-x64": "bun build src/main.ts --compile --target bun-darwin-x64   --outfile dist/covcom-macos-x64",
		"build:linux": "bun build src/main.ts --compile --target bun-linux-x64     --outfile dist/covcom-linux-x64",
		"build:win": "bun build src/main.ts --compile --target bun-windows-x64   --outfile dist/covcom-win-x64.exe"
	},
	"dependencies": {
		"@covcom/lib": "workspace:*",
		"leviathan-crypto": "3.0.1"
	},
	"devDependencies": {
		"@types/node": "^25.9.1",
		"bun-types": "^1.3.14"
	}
}
